AUTHENTIK_ISSUER_URL=https://auth.ocaindonesia.co.id/application/o/it-tools-portal/
AUTHENTIK_JWKS_URL=https://auth.ocaindonesia.co.id/application/o/it-tools-portal/jwks/
AUTHENTIK_AUTHORIZE_URL=https://auth.ocaindonesia.co.id/application/o/authorize/
AUTHENTIK_TOKEN_URL=https://auth.ocaindonesia.co.id/application/o/token/
AUTHENTIK_CLIENT_ID=it-tools-portal
AUTHENTIK_CLIENT_SECRET=<from Authentik client config>
AUTHENTIK_REDIRECT_URI=https://itools.ocaindonesia.co.id/callback
JWKS_CACHE_TTL_SECONDS=3600

JWT_PRIVATE_KEY_PATH=/run/secrets/it-tools-portal-private.pem
JWT_KID=v1
JWT_EXPIRY_SECONDS=90

FRAME_ANCESTORS=https://admin.ocaindonesia.co.id,https://*.fresp.my.id

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=it_tools_portal

PORT=8080
ENV=production
